# ── Supabase (required for accounts + cloud sync) ────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, used by the reminder cron.
# NEVER expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email reminders (optional, powers the renewal-warning cron) ──────────────
# https://resend.com → API Keys. Also verify a sending domain there.
RESEND_API_KEY=re_xxxxxxxx
REMINDER_FROM_EMAIL="SubSentry <alerts@yourdomain.com>"

# Secret that protects /api/cron/reminders. Vercel Cron sends it automatically
# as "Authorization: Bearer <CRON_SECRET>" once you set it in project env vars.
CRON_SECRET=generate-a-long-random-string

# ── Monetization (optional) ───────────────────────────────────────────────────
# Create a Payment Link in Stripe (e.g. $24/year "SubSentry Pro") and paste it.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxxx

# Canonical site URL (used for sitemap/SEO)
NEXT_PUBLIC_SITE_URL=https://subsentry.vercel.app
