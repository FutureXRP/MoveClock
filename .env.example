# MoveClock runs with ZERO env vars — everything below is optional.

# ── SEO / identity ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://moveclock.vercel.app
# Public contact address shown on /contact, /partners, and legal pages.
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# ── Monetization: affiliate slots ─────────────────────────────────────────────
# Until a URL is set, its slot links to /partners in preview mode. Paste your
# tracking URL from an affiliate network (Impact, CJ, FlexOffers, Awin…) and
# redeploy — the slot flips to a live external link with rel=sponsored.
NEXT_PUBLIC_AFFILIATE_MOVERS_URL=
NEXT_PUBLIC_AFFILIATE_INSURANCE_URL=
NEXT_PUBLIC_AFFILIATE_CARSHIP_URL=
NEXT_PUBLIC_AFFILIATE_INTERNET_URL=
