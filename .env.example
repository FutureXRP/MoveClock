# DepositBack runs with ZERO env vars — everything below is optional.

# ── Monetization (Stripe, optional) ───────────────────────────────────────────
# 1. In Stripe, create a Payment Link for a one-time $29 "Escalation Kit".
# 2. Set its confirmation page to redirect to:
#      https://YOUR-DOMAIN/kit?session_id={CHECKOUT_SESSION_ID}
# 3. Paste the link + your secret key here. Until both are set, the kit is
#    open free ("beta mode").
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxxx
STRIPE_SECRET_KEY=sk_live_xxxx

# ── SEO ───────────────────────────────────────────────────────────────────────
# Canonical site URL used in the sitemap and metadata.
NEXT_PUBLIC_SITE_URL=https://depositback.vercel.app
